<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mofadanqing.mapper.TraceNodeMapper">
    <select id="selectByOrderId" resultType="com.mofadanqing.entity.TraceNode">
        SELECT * FROM tms_trace_node WHERE order_id = #{orderId} ORDER BY action_time ASC
    </select>
</mapper>

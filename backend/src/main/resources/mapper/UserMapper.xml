<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mofadanqing.mapper.UserMapper">
    <select id="selectByUsername" resultType="com.mofadanqing.entity.User">
        SELECT * FROM sys_user WHERE username = #{username}
    </select>
    <select id="selectByPhone" resultType="com.mofadanqing.entity.User">
        SELECT * FROM sys_user WHERE phone = #{phone}
    </select>
    <select id="selectByEmail" resultType="com.mofadanqing.entity.User">
        SELECT * FROM sys_user WHERE email = #{email}
    </select>
</mapper>
